APP_NAME=Research Copilot
APP_ENV=local
LOG_LEVEL=INFO

# Paths are relative to project root by default.
DATA_DIR=data
OUTPUTS_DIR=outputs

# Connector mode:
# - "stub": local placeholder response (default)
# - "bridge": call a custom command that talks to NotebookLM MCP and returns JSON
NOTEBOOKLM_CONNECTOR_MODE=stub

# Used only in bridge mode.
# Command should read JSON from stdin:
# {"notebook_url":"...","question":"..."}
# and print JSON:
# {"answer":"...","sources":["..."],"raw":{...}}
NOTEBOOKLM_BRIDGE_COMMAND=python scripts/notebooklm_bridge.py

# Optional bridge tuning:
NOTEBOOKLM_MCP_COMMAND=npx -y notebooklm-mcp@latest
# If empty, bridge will auto-detect ask-like tool name.
NOTEBOOKLM_MCP_ASK_TOOL=
NOTEBOOKLM_MCP_TIMEOUT_SECONDS=45
